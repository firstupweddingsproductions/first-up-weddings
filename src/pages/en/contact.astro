---
import Layout from '../../layouts/Layout.astro';
---
<Layout lang="en" title="Contact" description="Tell us about your day. We look forward to hearing your story.">

  <section class="section-padding bg-brand-cream pt-32">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Left: Text -->
        <div>
          <h1 class="text-4xl md:text-5xl font-heading text-brand-dark mb-6">Tell us about your day.</h1>
          <p class="text-brand-text leading-relaxed mb-10">
            We look forward to hearing your story. Write to us, and we'll get back to you personally as soon as possible.
          </p>

          <div class="space-y-6">
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Email</h3>
              <a href="mailto:firstupweddings@gmail.com" class="text-brand-text hover:text-brand-accent transition-colors">firstupweddings@gmail.com</a>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Phone</h3>
              <a href="tel:+491732118910" class="text-brand-text hover:text-brand-accent transition-colors">+49 173 2118910</a>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Social media</h3>
              <div class="flex gap-4 text-brand-text">
                <a href="https://www.instagram.com/firstupweddings/" target="_blank" rel="noopener noreferrer" class="hover:text-brand-accent transition-colors">Instagram</a>
                <span>Vimeo</span>
                <a href="https://www.tiktok.com/@first.up.weddings?_r=1&_t=ZG-96CHznTQJDF" target="_blank" rel="noopener noreferrer" class="hover:text-brand-accent transition-colors">TikTok</a>
              </div>
            </div>
            <div>
              <h3 class="text-xs uppercase tracking-widest text-brand-accent mb-2">Location</h3>
              <p class="text-brand-text">Germany. Weddings nationwide and beyond.</p>
            </div>
          </div>

          <p class="text-sm text-brand-text/50 mt-10 italic">You don't need to have everything figured out yet. No perfect briefing required. Just write — we'll work out the rest together.</p>
        </div>

        <!-- Right: Form -->
        <div class="bg-brand-warm p-8 lg:p-10">
          <form id="contact-form" class="space-y-6" novalidate>
            <!-- Web3Forms access key for firstupweddings@gmail.com -->
            <input type="hidden" name="access_key" value="d6563e44-690a-485c-a92e-9bf1721c261b" />
            <input type="hidden" name="subject" value="New inquiry via First Up Weddings" />
            <input type="hidden" name="from_name" value="First Up Weddings Website" />
            <!-- Honeypot field (visually hidden but reachable to bots) -->
            <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" aria-hidden="true" />

            <div>
              <label for="names" class="block text-xs uppercase tracking-widest text-brand-text/60 mb-2">Your names *</label>
              <input type="text" id="names" name="names" required autocomplete="name" class="w-full bg-brand-cream border border-brand-dark/10 px-4 py-3 text-sm text-brand-dark focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="email" class="block text-xs uppercase tracking-widest text-brand-text/60 mb-2">Email *</label>
              <input type="email" id="email" name="email" required autocomplete="email" class="w-full bg-brand-cream border border-brand-dark/10 px-4 py-3 text-sm text-brand-dark focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="phone" class="block text-xs uppercase tracking-widest text-brand-text/60 mb-2">Phone number</label>
              <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="For a callback" class="w-full bg-brand-cream border border-brand-dark/10 px-4 py-3 text-sm text-brand-dark placeholder:text-brand-text/30 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="event_type" class="block text-xs uppercase tracking-widest text-brand-text/60 mb-2">Type of event</label>
              <select id="event_type" name="event_type" class="w-full bg-brand-cream border border-brand-dark/10 px-4 py-3 text-sm text-brand-dark focus:border-brand-accent focus:outline-none transition-colors cursor-pointer">
                <option value="">Please select</option>
                <option value="Wedding">Wedding</option>
                <option value="Engagement">Engagement</option>
                <option value="Civil ceremony">Civil ceremony</option>
                <option value="Proposal">Proposal</option>
                <option value="Couple shoot">Couple shoot</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div>
              <label for="date" class="block text-xs uppercase tracking-widest text-brand-text/60 mb-2">Your date *</label>
              <input type="text" id="date" name="date" required placeholder="Date or planned timeframe" class="w-full bg-brand-cream border border-brand-dark/10 px-4 py-3 text-sm text-brand-dark placeholder:text-brand-text/30 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="location" class="block text-xs uppercase tracking-widest text-brand-text/60 mb-2">Location</label>
              <input type="text" id="location" name="location" placeholder="If already known" class="w-full bg-brand-cream border border-brand-dark/10 px-4 py-3 text-sm text-brand-dark placeholder:text-brand-text/30 focus:border-brand-accent focus:outline-none transition-colors" />
            </div>
            <div>
              <label for="message" class="block text-xs uppercase tracking-widest text-brand-text/60 mb-2">Tell us about yourselves</label>
              <textarea id="message" name="message" rows="4" placeholder="What matters most to you about your day?" class="w-full bg-brand-cream border border-brand-dark/10 px-4 py-3 text-sm text-brand-dark placeholder:text-brand-text/30 focus:border-brand-accent focus:outline-none transition-colors resize-none"></textarea>
            </div>

            <button type="submit" id="contact-submit" class="btn-primary w-full text-center">Send message</button>

            <p id="contact-status" class="text-sm leading-relaxed hidden" role="status" aria-live="polite"></p>

            <p class="text-xs text-brand-text/50 leading-relaxed mt-2">
              By submitting, you agree that your details will be processed to respond to your inquiry. More information in the <a href="/en/privacy" class="underline hover:text-brand-accent transition-colors">privacy policy</a>.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-status') as HTMLParagraphElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

    if (form && status && submitBtn) {
      const originalLabel = submitBtn.textContent ?? 'Send message';

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        status.classList.remove('hidden', 'text-brand-accent', 'text-red-700');
        status.textContent = '';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending …';

        try {
          const formData = new FormData(form);
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData,
          });
          const json = await response.json();

          if (response.ok && json.success) {
            status.textContent = "Thank you! Your message has arrived. We'll get back to you personally as soon as possible.";
            status.classList.remove('hidden');
            status.classList.add('text-brand-accent');
            form.reset();
          } else {
            throw new Error(json.message || 'Submission failed');
          }
        } catch (error) {
          console.error(error);
          status.textContent = 'Something went wrong. Please write to us directly at firstupweddings@gmail.com — we reply quickly.';
          status.classList.remove('hidden');
          status.classList.add('text-red-700');
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalLabel;
        }
      });
    }
  </script>

</Layout>
