---
import { detectLang, getAlternateLocaleUrl, routes, type Lang } from '../i18n/routes';
import { t } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const currentPath = Astro.url.pathname;
const { lang = detectLang(currentPath) } = Astro.props;

const navItems = [
  { key: 'filmstil', href: routes[lang].filmstil, label: t(lang, 'nav.filmstil') },
  { key: 'euer-tag', href: routes[lang]['euer-tag'], label: t(lang, 'nav.euer-tag') },
  { key: 'ueber-mich', href: routes[lang]['ueber-mich'], label: t(lang, 'nav.ueber-mich') },
  { key: 'investition', href: routes[lang].investition, label: t(lang, 'nav.investition') },
  { key: 'kontakt', href: routes[lang].kontakt, label: t(lang, 'nav.kontakt') },
];

const homeHref = routes[lang].home;
const alternateHref = getAlternateLocaleUrl(currentPath, lang);

// Normalize current path so trailing-slash variants still match (Astro can emit either).
const normalizedCurrent = currentPath.replace(/\/+$/, '') || '/';
function isActive(href: string): boolean {
  const target = href.replace(/\/+$/, '') || '/';
  if (target === '/' || target === '/en') return normalizedCurrent === target;
  return normalizedCurrent === target || normalizedCurrent.startsWith(target + '/');
}
---
<header class="fixed top-0 left-0 right-0 z-50 bg-brand-cream/90 backdrop-blur-md border-b border-brand-dark/5">
  <nav class="flex items-center justify-between px-6 md:px-12 lg:px-24 py-5">
    <a href={homeHref} class="flex items-center gap-3 group">
      <img src="/logo.png" alt="First Up Weddings" class="h-10 w-auto shrink-0" />
      <span class="font-heading text-lg font-medium tracking-wide text-brand-dark group-hover:text-brand-accent transition-colors">
        First Up Weddings
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden lg:flex items-center gap-8">
      <ul class="flex items-center gap-8">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class:list={[
                'text-sm font-body tracking-wide transition-colors duration-200',
                isActive(item.href)
                  ? 'text-brand-accent'
                  : 'text-brand-text hover:text-brand-dark',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Language switcher (desktop) -->
      <div class="flex items-center gap-2 text-xs font-body tracking-wider" aria-label={t(lang, 'lang.switcher-aria')}>
        {lang === 'de' ? (
          <>
            <span class="text-brand-accent font-medium" aria-current="true">{t(lang, 'lang.de')}</span>
            <span class="text-brand-text/30">|</span>
            <a href={alternateHref} class="text-brand-text/60 hover:text-brand-dark transition-colors">{t(lang, 'lang.en')}</a>
          </>
        ) : (
          <>
            <a href={alternateHref} class="text-brand-text/60 hover:text-brand-dark transition-colors">{t(lang, 'lang.de')}</a>
            <span class="text-brand-text/30">|</span>
            <span class="text-brand-accent font-medium" aria-current="true">{t(lang, 'lang.en')}</span>
          </>
        )}
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden text-brand-dark p-2"
      aria-label={t(lang, 'nav.menu-open')}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-brand-cream border-t border-brand-dark/5">
    <ul class="flex flex-col px-6 py-6 gap-4">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block text-base font-body py-2 transition-colors',
              isActive(item.href)
                ? 'text-brand-accent'
                : 'text-brand-text hover:text-brand-dark',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-4 mt-2 border-t border-brand-dark/10">
        <div class="flex items-center gap-3 text-sm font-body tracking-wider" aria-label={t(lang, 'lang.switcher-aria')}>
          {lang === 'de' ? (
            <>
              <span class="text-brand-accent font-medium" aria-current="true">{t(lang, 'lang.de')}</span>
              <span class="text-brand-text/30">|</span>
              <a href={alternateHref} class="text-brand-text/60 hover:text-brand-dark transition-colors">{t(lang, 'lang.en')}</a>
            </>
          ) : (
            <>
              <a href={alternateHref} class="text-brand-text/60 hover:text-brand-dark transition-colors">{t(lang, 'lang.de')}</a>
              <span class="text-brand-text/30">|</span>
              <span class="text-brand-accent font-medium" aria-current="true">{t(lang, 'lang.en')}</span>
            </>
          )}
        </div>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

<div class="h-[73px]"></div>
